# Mr. Rex — runtime config. Copy to `.env` and fill in before building.
# The Supabase publishable key is client-visible by design; RLS must protect data.
# Never place a service-role key in Flutter or any committed client file.

DEMO_DIRECT_INTEGRATIONS=true

# --- AI: Gemini (text) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- CRM database: Supabase (preferred; shared with the website) ---
SUPABASE_URL=https://jptltprlzbcidkpbjipo.supabase.co
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=

# Aliases used by the Leads Agent web app; Flutter supports these too.
NEXT_PUBLIC_SUPABASE_URL=https://jptltprlzbcidkpbjipo.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Legacy CRM fallback: Leads Agent GitHub repo ---
GITHUB_TOKEN=
GITHUB_CRM_REPO=savinpadencherry/Focuschainlabs_Leads_Agent
GITHUB_CRM_PATH=data/crm/contacts.json
GITHUB_CRM_BRANCH=main
CRM_WEB_URL=

# --- Trello ---
TRELLO_KEY=
TRELLO_TOKEN=
TRELLO_LIST_ID=
TRELLO_BOARD_URL=
