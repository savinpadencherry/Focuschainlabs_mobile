# Mr. Rex — runtime config. Copy to `.env` and fill in before building.
# NOTE: `.env` is bundled into the app build (an asset), so treat these as
# client-visible for internal UAT only. Move integrations behind a backend
# proxy before any public release.
#
# DEMO_DIRECT_INTEGRATIONS=true keeps Gemini/GitHub/Trello calls in the client.
# Set to false when a backend Edge Function proxy is available.
DEMO_DIRECT_INTEGRATIONS=true
#
# After editing `.env` locally, keep your keys out of git with:
#   git update-index --skip-worktree .env

# --- AI: Gemini (text) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- CRM stored in the Leads Agent GitHub repo (data/crm/contacts.json) ---
# A GitHub PAT with "Contents: Read and write" on the repo below.
GITHUB_TOKEN=
GITHUB_CRM_REPO=savinpadencherry/Focuschainlabs_Leads_Agent
GITHUB_CRM_PATH=data/crm/contacts.json
GITHUB_CRM_BRANCH=main
# The Streamlit CRM URL opened in the in-app desktop webview.
CRM_WEB_URL=

# --- Trello (action items → board) ---
TRELLO_KEY=
TRELLO_TOKEN=
TRELLO_LIST_ID=
TRELLO_BOARD_URL=
